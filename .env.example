# Glyndwr v1.2 Configuration
# Copy this file to .env and fill in your values.
# You only need keys for providers you intend to use.
# All other settings (theme, model, email…) are changed inside the app.

# ── Server ──────────────────────────────────────────────────
APP_PORT=7860
APP_HOST=0.0.0.0

# ── AI Provider API Keys ─────────────────────────────────────
# Add at least one. Leave the rest blank.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROK_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ── Local / Self-hosted Inference ────────────────────────────
# Ollama, llama.cpp, vLLM, LM Studio — any OpenAI-compatible server.
# Leave blank if you are not running local models.
OLLAMA_HOST=http://localhost:11434

# ── Defaults (overridable in the app UI) ─────────────────────
DEFAULT_MODEL=gpt-4o-mini
